# Conexão com o banco de dados (Supabase/PostgreSQL)
# Substitua com suas credenciais reais
DATABASE_URL=postgresql://postgres:SUA_SENHA@db.PROJETO.supabase.co:5432/postgres

# Segredo para assinar tokens JWT (gere um valor aleatório longo)
SECRET_KEY=troque-por-um-segredo-muito-longo-e-aleatorio

# Algoritmo JWT (não alterar)
ALGORITHM=HS256

# Tempo de expiração do token em minutos
ACCESS_TOKEN_EXPIRE_MINUTES=1440
